# syntax=docker/dockerfile:1.7
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /out/mastermind-mcp ./cmd/mastermind-mcp

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app
COPY --from=build /out/mastermind-mcp /app/mastermind-mcp
USER nonroot:nonroot
ENTRYPOINT ["/app/mastermind-mcp"]
